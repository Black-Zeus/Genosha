# ==========================================================
# Genosha — Template de variables de entorno
# Copiar como .env y ajustar según el ambiente
# El archivo .env.dev (o .env.qa / .env.prd) contiene los
# overrides específicos de cada ambiente.
# ==========================================================

PROJECT_NAME=genosha
ENV=dev

# Rutas de almacenamiento (relativas a Sistema/)
DATA_ROOT=./volumenes
LOGS_ROOT=./Logs
VOLUMES_ROOT=./volumenes
SHARE_ROOT=./share
CONFIGS_ROOT=./Configs
SECRETS_ROOT=./secrets

# PostgreSQL
POSTGRES_HOST=genosha-postgres
POSTGRES_PORT=5432
POSTGRES_DB=genosha_dev
POSTGRES_USER=genosha
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=genosha-redis
REDIS_PORT=6379
REDIS_URL=redis://genosha-redis:6379/0
CELERY_BROKER_URL=redis://genosha-redis:6379/0
CELERY_RESULT_BACKEND=redis://genosha-redis:6379/1

# Qdrant
QDRANT_HOST=genosha-qdrant
QDRANT_PORT=6333
QDRANT_URL=http://genosha-qdrant:6333

# MinIO
MINIO_HOST=genosha-minio
MINIO_PORT=9000
MINIO_ROOT_USER=genosha
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=genosha-dev

# Gotenberg
GOTENBERG_HOST=genosha-gotenberg
GOTENBERG_PORT=3000
GOTENBERG_URL=http://genosha-gotenberg:3000

# API
API_HOST=genosha-api
API_PORT=8000
SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY
DEBUG=false
